<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Partial Info.plist for the xLights-iPad target.

  The target keeps GENERATE_INFOPLIST_FILE = YES so Xcode auto-fills
  the standard CFBundle*, UIApplicationSceneManifest, UISupportedInterface*
  keys. This file contributes only the pieces Xcode build settings
  can't express: the .xsq document-type declaration. Xcode merges
  the generated keys on top of these.

  G-3 — registering .xsq makes the Files app offer "Open in xLights"
  when the user taps a sequence, and tells iPadOS that xLights owns
  the org.xlights.sequence UTI.

  `.xsqz` (compressed sequence package) is intentionally NOT
  registered here — `src-core/render/SequencePackage.cpp` extracts
  `.xsqz` / `.zip` / `.piz` containers on desktop and routes to the
  inner `.xsq`, but that logic isn't wired into the iPad bridge.
  Advertising `.xsqz` support would route taps into xLights that
  we can't actually fulfil. Revisit when SequencePackage is
  integrated on iPad.
-->
<plist version="1.0">
<dict>
  <!--
    H-4 — export compliance. Without this, every TestFlight upload
    blocks at App Store Connect asking whether the build uses
    encryption. xLights only uses Apple-provided HTTPS/TLS (via
    NSURLSession and Bonjour) which is exempt from export reporting.
    `ITSAppUsesNonExemptEncryption = false` is Apple's standard
    "yes but it's all exempt" declaration; once set, TestFlight
    stops prompting per build.

    If we ever ship a feature that does custom crypto (signing an
    upload with a non-standard algorithm, bundled OpenSSL, etc.)
    this needs to flip to `true` and we'd also need to file the
    annual self-classification report with BIS.
  -->
  <key>ITSAppUsesNonExemptEncryption</key>
  <false/>

  <!--
    G-3 follow-up: these two flags are what separates "shows up in
    the share sheet" (UTI registration alone does that) from
    "shows up in Files' long-press Open With menu and opens files
    in place." Without them, iPadOS classifies us as a receive-
    via-share target but not a direct-open target.

    LSSupportsOpeningDocumentsInPlace — we can read/write the file
      at its existing location (via the security-scoped bookmark
      `ObtainAccessToURL` mints in `.onOpenURL`) without needing a
      copy into our sandbox.
    UIFileSharingEnabled — exposes our `Documents/` directory in
      Files so users can also navigate into it from outside; not
      strictly required for Open With but the conventional
      companion flag.
  -->
  <key>LSSupportsOpeningDocumentsInPlace</key>
  <true/>
  <key>UIFileSharingEnabled</key>
  <true/>

  <!--
    H-3 — network-access declarations. Controller output
    (sACN / ArtNet / DDP / OPC) and controller discovery are
    not in the MVP UI, but the C++ core (`src-core/outputs/`,
    `src-core/discovery/`, `src-core/controllers/FPP.cpp`) can
    still reach for local-network sockets in any code path that
    touches `OutputManager` or `Discovery`. Without these
    declarations iOS aborts the app with "missing
    NSLocalNetworkUsageDescription" the first time a socket
    opens. Declared up-front so dev + beta paths don't trip
    over it; the description copy is honest about what the
    app eventually does even if the UI is hidden for v1.

    `_fppd._udp` is the only Bonjour service the core
    currently advertises / browses for (Falcon Player daemon).
    Extend this list as more discovery types light up.
  -->
  <key>NSLocalNetworkUsageDescription</key>
  <string>xLights discovers lighting controllers on your local network (Falcon Player, sACN / ArtNet / DDP devices) and streams pixel data to them during playback.</string>
  <key>NSBonjourServices</key>
  <array>
    <string>_fppd._udp</string>
  </array>

  <!--
    H-1 — launch screen. iPadOS 14+ requires a UILaunchScreen dict
    (static LaunchImage catalogs are disallowed for new submissions).

    `UIColorName = LaunchBackground` and `UIImageName = LaunchLogo`
    resolve against `src-iPad/Assets.xcassets/`. LaunchBackground has
    explicit light (white) and dark (#1A1A1A) appearance variants so
    the launch matches the user's iPad appearance mode. LaunchLogo is
    the xLights horizontal logo as a single @2x PNG (1200×460 →
    600×230 pt on-screen); iOS centers it automatically.

    The `INFOPLIST_KEY_UILaunchScreen_Generation = YES` build setting
    that was previously on this target is removed — it emits an empty
    UILaunchScreen dict, and having both that build setting AND this
    explicit dict is redundant / confusing. Our dict is authoritative.
  -->
  <key>UILaunchScreen</key>
  <dict>
    <key>UIColorName</key>
    <string>LaunchBackground</string>
    <key>UIImageName</key>
    <string>LaunchLogo</string>
    <key>UIImageRespectsSafeAreaInsets</key>
    <true/>
  </dict>

  <key>CFBundleDocumentTypes</key>
  <array>
    <dict>
      <key>CFBundleTypeName</key>
      <string>xLights Sequence</string>
      <key>CFBundleTypeRole</key>
      <string>Editor</string>
      <key>LSHandlerRank</key>
      <string>Owner</string>
      <key>LSItemContentTypes</key>
      <array>
        <string>org.xlights.sequence</string>
      </array>
    </dict>
  </array>

  <key>UTExportedTypeDeclarations</key>
  <array>
    <dict>
      <key>UTTypeIdentifier</key>
      <string>org.xlights.sequence</string>
      <key>UTTypeDescription</key>
      <string>xLights Sequence</string>
      <key>UTTypeConformsTo</key>
      <array>
        <string>public.xml</string>
        <string>public.data</string>
      </array>
      <key>UTTypeTagSpecification</key>
      <dict>
        <key>public.filename-extension</key>
        <array>
          <string>xsq</string>
        </array>
      </dict>
    </dict>
  </array>
</dict>
</plist>
