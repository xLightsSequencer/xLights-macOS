#!/bin/bash

# Mac-specific build-phase script: embed metallibs, stamp bundle versions
# (via the shared set_bundle_version script), rewrite wx dylib rpaths, and
#
# The version stamping lives in scripts/set_bundle_version so the iPad
# target can reuse the same logic — see that script's header for the
# numbering scheme.


SCRIPTDIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null && pwd )"

cp $TARGET_BUILD_DIR/*.metallib $TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/Resources
cp $PROJECT_TEMP_ROOT/UninstalledProducts/macosx/*.metallib $TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/Resources

"${SCRIPTDIR}/set_bundle_version"


PROCESSED_DYLIBS=""

fix_wx_dylib_rpaths() {
    local DYLIB="$1"

    if [ ! -f "$DYLIB" ]; then
        return
    fi

    # Skip if already processed
    local RESOLVED
    RESOLVED=$(cd "$(dirname "$DYLIB")" && pwd)/$(basename "$DYLIB")
    if echo "$PROCESSED_DYLIBS" | grep -qF "$RESOLVED"; then
        return
    fi
    PROCESSED_DYLIBS="$PROCESSED_DYLIBS|$RESOLVED"

    # Find the absolute prefix used by the CI runner for wx dylibs
    local SRCLOCATION
    SRCLOCATION=$(otool -L "$DYLIB" | grep xLights-macOS-dependencies | head -1 | awk '{print $1}')
    if [ -z "$SRCLOCATION" ]; then
        return
    fi
    # Strip everything from /libwx onward to get the directory prefix
    SRCLOCATION=${SRCLOCATION%/lib*}

    local LIBS
    LIBS=$(otool -L "$DYLIB" | grep xLights-macOS-dependencies | awk '{print $1}')
    for FULLPATH in $LIBS
    do
        local LIBNAME
        LIBNAME=${FULLPATH#${SRCLOCATION}/}
        install_name_tool -change "$FULLPATH" "@rpath/$LIBNAME" "$DYLIB" 2> /dev/null
    done
    install_name_tool -add_rpath "${PROJECT_DIR}/dependencies/libdbg" "$DYLIB" 2> /dev/null || true

    # Recursively fix any wx dylibs that this dylib depends on
    local LIBDIR="${PROJECT_DIR}/dependencies/libdbg"
    for FULLPATH in $LIBS
    do
        local DEPNAME
        DEPNAME=$(basename "$FULLPATH")
        if [ -f "$LIBDIR/$DEPNAME" ]; then
            fix_wx_dylib_rpaths "$LIBDIR/$DEPNAME"
        fi
    done
}

# Xcode IDE builds (ENABLE_DEBUG_DYLIB=YES) put all the wx references in
# xLights.debug.dylib and leave the .app/Contents/MacOS/xLights launcher as a
# tiny shim. CLI `xcodebuild` does not produce the debug dylib, so the wx refs
# live in the monolithic executable instead. Rewrite whichever one exists.
if [ "$CONFIGURATION" == "Debug" ]; then
    TARGET_BIN="$TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/MacOS/xLights.debug.dylib"
    if [ ! -f "$TARGET_BIN" ]; then
        TARGET_BIN="$TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/MacOS/$PRODUCT_NAME"
    fi
    if [ -f "$TARGET_BIN" ]; then
        fix_wx_dylib_rpaths "$TARGET_BIN"
    fi
fi


