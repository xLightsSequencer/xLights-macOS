#!/bin/bash

# This script primarily grabs the version number from xLightsVersion.h or xlights_build_version.h
# and uses that to set the CFBundleVersion strings that are needed for the app store upload.
# This really just prevents having to adjust the xcodeproject version numbers every build


SCRIPTDIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null && pwd )"
if [ -f "${SCRIPTDIR}/../../xLights/xlights_build_version.h" ]; then
    XLVERSION=$(grep xlights_version_string ${SCRIPTDIR}/../../src-core/xlights_build_version.h | tr "\"" "\n" | grep 20)
else
    XLVERSION=$(grep xlights_version_string ${SCRIPTDIR}/../../src-core/xLightsVersion.h | tr "\"" "\n" | grep 20)
fi

# iff need to manually force a version number
#XLVERSION=2024.01.3
#That will create build number of 2401003


SHORTVER="${XLVERSION//./0}"
SHORTVERPFX="${SHORTVER:2:2}${SHORTVER:5:2}"
SHORTVERPO=${SHORTVER:8}
printf -v SHORTVERPO "%03d" $SHORTVERPO
SHORTVER="${SHORTVERPFX}${SHORTVERPO}"

cp $TARGET_BUILD_DIR/*.metallib $TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/Resources
cp $PROJECT_TEMP_ROOT/UninstalledProducts/macosx/*.metallib $TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/Resources

/usr/libexec/PlistBuddy -c "Set :CFBundleShortVersionString $XLVERSION" "${TARGET_BUILD_DIR}/${INFOPLIST_PATH}"
/usr/libexec/PlistBuddy -c "Set :CFBundleVersion $SHORTVER" "${TARGET_BUILD_DIR}/${INFOPLIST_PATH}"


PROCESSED_DYLIBS=""

fix_wx_dylib_rpaths() {
    local DYLIB="$1"

    if [ ! -f "$DYLIB" ]; then
        return
    fi

    # Skip if already processed
    local RESOLVED
    RESOLVED=$(cd "$(dirname "$DYLIB")" && pwd)/$(basename "$DYLIB")
    if echo "$PROCESSED_DYLIBS" | grep -qF "$RESOLVED"; then
        return
    fi
    PROCESSED_DYLIBS="$PROCESSED_DYLIBS|$RESOLVED"

    # Find the absolute prefix used by the CI runner for wx dylibs
    local SRCLOCATION
    SRCLOCATION=$(otool -L "$DYLIB" | grep xLights-macOS-dependencies | head -1 | awk '{print $1}')
    if [ -z "$SRCLOCATION" ]; then
        return
    fi
    # Strip everything from /libwx onward to get the directory prefix
    SRCLOCATION=${SRCLOCATION%/lib*}

    local LIBS
    LIBS=$(otool -L "$DYLIB" | grep xLights-macOS-dependencies | awk '{print $1}')
    for FULLPATH in $LIBS
    do
        local LIBNAME
        LIBNAME=${FULLPATH#${SRCLOCATION}/}
        install_name_tool -change "$FULLPATH" "@rpath/$LIBNAME" "$DYLIB" 2> /dev/null
    done
    install_name_tool -add_rpath "${PROJECT_DIR}/dependencies/libdbg" "$DYLIB" 2> /dev/null || true

    # Recursively fix any wx dylibs that this dylib depends on
    local LIBDIR="${PROJECT_DIR}/dependencies/libdbg"
    for FULLPATH in $LIBS
    do
        local DEPNAME
        DEPNAME=$(basename "$FULLPATH")
        if [ -f "$LIBDIR/$DEPNAME" ]; then
            fix_wx_dylib_rpaths "$LIBDIR/$DEPNAME"
        fi
    done
}

if [ -f "$TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/MacOS/xLights.debug.dylib" ]; then
    fix_wx_dylib_rpaths "$TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/MacOS/xLights.debug.dylib"
fi

# --- ANGLE dylibs (OpenGL ES via Metal) ---
# When USE_GLES is defined, the app links against libEGL.dylib and libGLESv2.dylib.
# These must be copied into the Frameworks folder so @rpath resolution works at runtime.
embed_angle_dylibs() {
    local FRAMEWORKS_DIR="$TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/Frameworks"
    local LIBDIR

    # Pick the right library directory based on build configuration
    if [ "$CONFIGURATION" == "Debug" ]; then
        LIBDIR="${PROJECT_DIR}/dependencies/libdbg"
    else
        LIBDIR="${PROJECT_DIR}/dependencies/lib"
    fi

    # Only embed if ANGLE dylibs exist in the dependencies
    if [ ! -f "$LIBDIR/libEGL.dylib" ]; then
        return
    fi

    # Check if the binary actually links against ANGLE
    if ! otool -L "$TARGET_BUILD_DIR/$PRODUCT_NAME.app/Contents/MacOS/$PRODUCT_NAME" | grep -q "libEGL\|libGLESv2"; then
        return
    fi

    echo "Embedding ANGLE dylibs from $LIBDIR"
    mkdir -p "$FRAMEWORKS_DIR"
    cp "$LIBDIR/libEGL.dylib" "$FRAMEWORKS_DIR/"
    cp "$LIBDIR/libGLESv2.dylib" "$FRAMEWORKS_DIR/"

    # Ad-hoc sign for Debug, use the build's signing identity for Release/Archive
    local SIGN_IDENTITY
    if [ -n "$EXPANDED_CODE_SIGN_IDENTITY" ] && [ "$EXPANDED_CODE_SIGN_IDENTITY" != "-" ]; then
        SIGN_IDENTITY="$EXPANDED_CODE_SIGN_IDENTITY"
    else
        SIGN_IDENTITY="-"
    fi
    /usr/bin/codesign --force --sign "$SIGN_IDENTITY" "$FRAMEWORKS_DIR/libEGL.dylib"
    /usr/bin/codesign --force --sign "$SIGN_IDENTITY" "$FRAMEWORKS_DIR/libGLESv2.dylib"
}

embed_angle_dylibs

